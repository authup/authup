{
    "name": "@authup/access",
    "type": "module",
    "version": "1.0.0-beta.40",
    "description": "A library for evaluating permissions and policies.",
    "license": "Apache-2.0",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        }
    },
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
        "build:js": "tsdown",
        "build": "rimraf ./dist && npm run build:js && npm run build:types",
        "test": "cross-env NODE_ENV=test vitest run",
        "test:coverage": "cross-env NODE_ENV=test vitest run --coverage"
    },
    "engines": {
        "node": "^20.19.0 || ^22.13.0 || ^23.5.0 || >=24.0.0"
    },
    "keywords": [
        "auth",
        "authorization",
        "permission",
        "policy",
        "rbac",
        "abac",
        "access-control",
        "policy-engine",
        "permission-evaluator",
        "decision-strategy"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/authup/authup.git",
        "directory": "packages/access"
    },
    "bugs": {
        "url": "https://github.com/authup/authup/issues"
    },
    "homepage": "https://github.com/authup/authup#readme",
    "dependencies": {
        "@ucast/mongo2js": "^2.0.0",
        "@validup/adapter-zod": "^0.2.4",
        "pathtrace": "^2.2.0",
        "validup": "^0.2.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@authup/errors": "^1.0.0-beta.40",
        "@authup/kit": "^1.0.0-beta.40",
        "unplugin-swc": "^1.5.9",
        "vitest": "^4.0.14"
    },
    "peerDependencies": {
        "@authup/errors": "^1.0.0-beta.40",
        "@authup/kit": "^1.0.0-beta.40"
    },
    "publishConfig": {
        "access": "public"
    }
}

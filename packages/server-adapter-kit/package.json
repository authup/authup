{
    "name": "@authup/server-adapter-kit",
    "type": "module",
    "version": "1.0.0-beta.35",
    "description": "A package containing a toolkit for server side adapters",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        }
    },
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist/"
    ],
    "engines": {
        "node": "^20.19.0 || ^22.13.0 || ^23.5.0 || >=24.0.0"
    },
    "scripts": {
        "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
        "build:js": "tsdown",
        "build": "rimraf ./dist && npm run build:js && npm run build:types",
        "test": "cross-env NODE_ENV=test vitest run test/unit",
        "test:coverage": "cross-env NODE_ENV=test vitest run --coverage"
    },
    "keywords": [
        "auth",
        "authentication",
        "token-verification",
        "jwt",
        "cache",
        "middleware",
        "server",
        "adapter",
        "bearer-token"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/authup/authup.git",
        "directory": "packages/server-adapter-kit"
    },
    "bugs": {
        "url": "https://github.com/authup/authup/issues"
    },
    "homepage": "https://github.com/authup/authup#readme",
    "dependencies": {
        "@authup/kit": "^1.0.0-beta.35",
        "@authup/errors": "^1.0.0-beta.35",
        "@authup/specs": "^1.0.0-beta.35",
        "@authup/core-kit": "^1.0.0-beta.35",
        "@authup/core-http-kit": "^1.0.0-beta.35",
        "@authup/server-kit": "^1.0.0-beta.35",
        "@hapic/oauth2": "^3.2.0",
        "@isaacs/ttlcache": "^2.1.4",
        "jose": "^6.2.2",
        "redis-extension": "^2.0.4"
    },
    "devDependencies": {
        "vitest": "^4.0.18"
    },
    "publishConfig": {
        "access": "public"
    }
}

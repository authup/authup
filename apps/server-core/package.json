{
    "name": "@authup/server-core",
    "type": "module",
    "version": "1.0.0-beta.38",
    "description": "This is a standalone application.",
    "license": "Apache-2.0",
    "main": "dist/index.mjs",
    "module": "dist/index.mjs",
    "files": [
        "dist"
    ],
    "scripts": {
        "debug": "node --inspect dist/cli/index.mjs start",
        "cli": "node dist/cli/index.mjs",
        "cli-dev": "npm run build:server && npm run cli",
        "cli-dev-src": "nodemon --watch src --exec \"npm run build:server && node dist/cli/index.mjs\"",
        "cli-dev-dist": "nodemon --watch dist --exec \"node dist/cli/index.mjs\"",
        "build:ui:client": "vite build --config ui/vite.config.ts --ssrManifest .vite/ssr-manifest.json --outDir ../dist/ui/client ui",
        "build:ui:server": "vite build --config ui/vite.config.ts --ssr src/server.ts --outDir ../dist/ui/server ui",
        "build:ui": "npm run build:ui:server && npm run build:ui:client",
        "build:server:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
        "build:server:js": "tsdown",
        "build:server": "npm run build:server:js && npm run build:server:types",
        "build:swagger": "npm run cli -- swagger generate",
        "build": "rimraf ./dist && npm run build:server && npm run build:ui && npm run build:swagger",
        "test": "cross-env NODE_ENV=test vitest run --config test/vitest.config.ts",
        "test:mysql": "cross-env DB_TYPE=mysql DB_HOST=127.0.0.1 DB_USERNAME=root DB_PASSWORD=start123 DB_DATABASE=app vitest run --config test/vitest.config.ts",
        "test:psql": "cross-env DB_TYPE=postgres DB_HOST=127.0.0.1 DB_USERNAME=postgres DB_PASSWORD=start123 DB_DATABASE=app vitest run --config test/vitest.config.ts",
        "test:coverage": "cross-env NODE_ENV=test vitest run --config test/vitest.config.ts --coverage"
    },
    "engines": {
        "node": "^20.19.0 || ^22.13.0 || ^23.5.0 || >=24.0.0"
    },
    "bin": {
        "authup-server": "dist/cli/index.mjs"
    },
    "keywords": [
        "auth",
        "authentication",
        "authorization",
        "oauth2",
        "openid-connect",
        "server",
        "api",
        "iam",
        "rbac",
        "abac",
        "ldap",
        "jwt",
        "identity",
        "access-control",
        "token",
        "session"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/authup/authup.git",
        "directory": "packages/server-core"
    },
    "bugs": {
        "url": "https://github.com/authup/authup/issues"
    },
    "homepage": "https://github.com/authup/authup#readme",
    "dependencies": {
        "@authup/access": "^1.0.0-beta.38",
        "@authup/core-http-kit": "^1.0.0-beta.38",
        "@authup/core-kit": "^1.0.0-beta.38",
        "@authup/errors": "^1.0.0-beta.38",
        "@authup/kit": "^1.0.0-beta.38",
        "@authup/server-kit": "^1.0.0-beta.38",
        "@authup/specs": "^1.0.0-beta.38",
        "@ebec/http": "^2.3.0",
        "@hapic/oauth2": "^3.2.0",
        "@routup/assets": "^3.4.2",
        "@routup/basic": "^1.4.3",
        "@routup/decorators": "^3.4.3",
        "@routup/prometheus": "^2.4.2",
        "@routup/rate-limit": "^2.4.2",
        "@routup/swagger": "^2.4.3",
        "@validup/adapter-routup": "^0.2.2",
        "@validup/adapter-validator": "^0.3.2",
        "@validup/adapter-zod": "^0.2.4",
        "better-sqlite3": "^12.8.0",
        "citty": "^0.2.2",
        "confinity": "^1.0.0-beta.1",
        "cors": "^2.8.6",
        "dotenv": "^17.4.1",
        "dycraft": "^1.1.0",
        "eldin": "^1.1.0",
        "envix": "^1.5.0",
        "hapic": "^2.5.1",
        "ldapjs": "^3.0.7",
        "locter": "^2.2.1",
        "morgan": "^1.10.1",
        "mysql2": "^3.22.1",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.5",
        "orkos": "^1.1.1",
        "pg": "^8.20.0",
        "rapiq": "^0.9.0",
        "reflect-metadata": "^0.2.2",
        "routup": "^4.1.0",
        "singa": "^1.1.0",
        "smob": "^1.6.1",
        "tsyringe": "^4.10.0",
        "typeorm": "^0.3.28",
        "typeorm-extension": "^3.9.0",
        "uncrypto": "^0.1.3",
        "validup": "^0.2.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@authup/client-web-kit": "^1.0.0-beta.38",
        "@faker-js/faker": "^10.4.0",
        "@fortawesome/fontawesome-free": "^7.2.0",
        "@types/cors": "^2.8.19",
        "@types/ldapjs": "^3.0.6",
        "@types/morgan": "^1.9.10",
        "@types/supertest": "^7.2.0",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vuecs/countdown": "^1.0.1",
        "@vuecs/form-controls": "^2.5.0",
        "@vuecs/list-controls": "^2.0.1",
        "@vuecs/navigation": "^2.4.1",
        "@vuecs/pagination": "^1.3.1",
        "@vuecs/preset-bootstrap-v5": "^2.0.1",
        "@vuecs/preset-font-awesome": "^1.1.1",
        "@vuecs/timeago": "^1.1.2",
        "@vuelidate/core": "^2.0.3",
        "@vuelidate/validators": "^2.0.4",
        "bootstrap": "^5.3.8",
        "jest-serial-runner": "^1.2.1",
        "nodemon": "^3.1.14",
        "pinia": "^3.0.0",
        "supertest": "^7.2.2",
        "testcontainers": "^11.14.0",
        "ts-node": "^10.8.2",
        "unplugin-swc": "^1.5.9",
        "vite": "^8.0.9",
        "vitest": "^4.0.14",
        "vue": "^3.5.32",
        "vue-router": "^5.0.4"
    },
    "publishConfig": {
        "access": "public"
    }
}

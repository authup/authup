{
    "include-component-in-tag": false,
    "release-type": "node",
    "release-as": "1.0.0-beta.37",
    "packages": {
        ".": {"component": "root"},

        "apps/authup": {"component": "authup"},
        "apps/client-web": {"component": "client-web"},
        "apps/server-core": {"component": "server-core"},

        "packages/access": {"component": "access"},
        "packages/client-web-kit": {"component": "client-web-kit"},
        "packages/client-web-nuxt": {"component": "client-web-nuxt"},
        "packages/core-http-kit": {"component": "core-http-kit"},
        "packages/core-kit": {"component": "core-kit"},
        "packages/core-realtime-kit": {"component": "core-realtime-kit"},
        "packages/errors": {"component": "errors"},
        "packages/kit": {"component": "kit"},
        "packages/server-adapter-http": {"component": "server-adapter-http"},
        "packages/server-adapter-kit": {"component": "server-adapter-kit"},
        "packages/server-adapter-socket-io": {"component": "server-adapter-socket-io"},
        "packages/server-kit": {"component": "server-kit"},
        "packages/specs": {"component": "specs"}
    },
    "plugins": [
        {
            "updateAllPackages": true,
            "type": "node-workspace",
            "updatePeerDependencies": true
        },
        {
            "type": "linked-versions",

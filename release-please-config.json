            "components": [
                "root",

                "authup",
                "client-web",
                "server-core",

                "access",
                "client-web-kit",
                "client-web-nuxt",
                "core-http-kit",
                "core-kit",
                "core-realtime-kit",
                "errors",
                "kit",

                "server-adapter-http",
                "server-adapter-kit",
                "server-adapter-socket-io",
                "server-kit",
                "specs"
            ]
        }
    ],
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json"
}
